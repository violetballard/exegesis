{
  "provider": "codex",
  "description": "Codex/OpenAI cloud profiles mapped onto the normalized cloud tiers.",
  "top_level": {
    "model": "gpt-5.1-codex",
    "codex_cmd": "/Applications/Codex.app/Contents/Resources/codex"
  },
  "profiles": {
    "worker_cloud": {
      "harness": "codex",
      "codex_cmd": "/Applications/Codex.app/Contents/Resources/codex",
      "codex_args": ["-c", "model_context_window=256000"],
      "model": "gpt-5.5",
      "model_args": ["-c", "model_reasoning_effort=low"]
    },
    "worker_cloud_standard_medium": {
      "harness": "codex",
      "codex_cmd": "/Applications/Codex.app/Contents/Resources/codex",
      "codex_args": ["-c", "model_context_window=256000"],
      "model": "gpt-5.5",
      "model_args": ["-c", "model_reasoning_effort=medium"]
    },
    "integrator_cloud": {
      "harness": "codex",
      "codex_cmd": "/Applications/Codex.app/Contents/Resources/codex",
      "codex_args": ["-c", "model_context_window=256000"],
      "model": "gpt-5.5",
      "model_args": ["-c", "model_reasoning_effort=high"]
    }
  },
  "role_profiles": {
    "cloud_probe": "worker_cloud",
    "feature_cloud": "worker_cloud",
    "reviewer_cloud": "worker_cloud_standard_medium",
    "fixer_cloud": "worker_cloud_standard_medium",
    "integrator_cloud": "integrator_cloud"
  }
}
